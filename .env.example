# ===========================================
# AgriMind AI — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- MongoDB Atlas (AgriMind-AI cluster) ---
# Copy your connection string from Atlas → Connect → Drivers.
# Example (app adds /agrimind database + retryWrites if missing):
MONGODB_URI=mongodb+srv://Afnan:YOUR_PASSWORD@agrimind-ai.xyt2joj.mongodb.net/?appName=AgriMind-AI

# --- Firebase Client (from Firebase Console > Project Settings) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (Project Settings → Service accounts → Generate new private key) ---
# Use client_email + private_key from JSON — do NOT commit the JSON file
FIREBASE_ADMIN_PROJECT_ID=agrimind-ait4d
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@agrimind-ait4d.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_KEY_WITH_\n_ESCAPED_NEWLINES\n-----END PRIVATE KEY-----\n"

# --- Image storage (required for diagnosis photos in MongoDB history) ---
# MongoDB stores HTTPS URLs only — images upload to cloud first.
# Option A — Cloudinary (recommended): https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Option B — Firebase Storage (uses Admin credentials above + bucket from Firebase Console)
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# (or use NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET — same value)

# --- WhatsApp officer support (E.164 without +) ---
NEXT_PUBLIC_WHATSAPP_SUPPORT=94772117131

# --- OpenAI (server-only — chat, crop vision diagnosis) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1500
# Text-to-speech for voice assistant (tts-1 or tts-1-hd)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# --- Valsea AI (server-only — never expose to client) ---
VALSEA_API_KEY=
VALSEA_API_BASE_URL=https://api.valsea.ai

# --- Firebase Analytics (optional) ---
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Google Weather API (real-time — enable "Weather API" in Google Cloud Console) ---
# https://developers.google.com/maps/documentation/weather/get-api-key
GOOGLE_WEATHER_API_KEY=

# --- Market data (optional manual refresh) ---
# npx tsx --env-file=.env.local scripts/seed-market.ts
# npm run seed:market

# --- Sample farm crops for a user (Firebase UID from Firebase Console) ---
# npm run seed:crops -- <firebase-uid>
